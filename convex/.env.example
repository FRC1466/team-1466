# These are Convex deployment environment variables.
# Set them with: bunx convex env set VAR_NAME "value"
# Or via the Convex dashboard → Settings → Environment Variables.

# ─── Convex Auth ──────────────────────────────────────────────────────────────
CONVEX_SITE_URL=https://YOUR_TEAM1466_DEPLOYMENT.convex.site
JWT_PRIVATE_KEY=        # generated by `bunx @convex-dev/auth`
JWKS=                   # generated by `bunx @convex-dev/auth`

# ─── WebbPower Integration ────────────────────────────────────────────────────
# Shared secret for the /internal/member-lookup endpoint.
# Must match the TEAM_DASHBOARD_API_KEY in the WebbPower Convex deployment.
TEAM_DASHBOARD_API_KEY=your-shared-secret-here
